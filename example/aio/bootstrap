#/bin/sh
export CONTAINER_EP=unix:///var/run/runtime-launcher.sock
mkdir -p /tmp/yr_sessions/
/usr/local/bin/traefik --configFile=/openyuanrong/traefik/traefik.yml >> /tmp/yr_sessions/traefik.log 2>&1 &
/openyuanrong/runtime-launcher >> /tmp/yr_sessions/runtime_launcher.log 2>&1 & 
yr start --master \
	--port_policy FIX \
	--enable_faas_frontend=true \
	--faas_frontend_http_port 8889 \
	--enable_function_scheduler true \
    --enable_meta_service true \
    --ssl_base_path /openyuanrong/cert \
    --frontend_ssl_enable true \
	--enable_iam_server $ENABLE_TOKEN \
	--frontend_client_auth_type NoClientCert \
	--enable_function_token_auth $ENABLE_TOKEN \
	--block \
	-p /openyuanrong/services.yaml
